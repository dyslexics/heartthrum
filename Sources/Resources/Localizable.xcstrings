    "Measure": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Messen"
          }
        }
      }
    },
    "History": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verlauf"
          }
        }
      }
    },
    "Breathe": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Atmen"
          }
        }
      }
    },
    "Settings": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einstellungen"
          }
        }
      }
    },
    "Welcome to Heartthrum": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Willkommen bei Heartthrum"
          }
        }
      }
    },
    "Measure your pulse with your fingertip — right on your iPhone's camera.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Miss deinen Puls mit der Fingerspitze – direkt an der Kamera deines iPhones."
          }
        }
      }
    },
    "Free. No ads. No tracking. Your data stays on your device.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kostenlos. Keine Werbung. Kein Tracking. Deine Daten bleiben auf deinem Gerät."
          }
        }
      }
    },
    "Follow your well-being over time and relax with guided breathing.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge dein Wohlbefinden über die Zeit und entspanne mit geführten Atemübungen."
          }
        }
      }
    },
    "Heartthrum is not a medical device. Measurements are for wellness and general well-being purposes only and do not replace professional medical advice.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Heartthrum ist kein Medizinprodukt. Die Messungen dienen ausschließlich dem Wohlbefinden und ersetzen keine ärztliche Beratung."
          }
        }
      }
    },
    "Get Started": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Los geht's"
          }
        }
      }
    },
    "Cover the back camera and flash with your fingertip.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege deine Fingerspitze auf die Rückkamera und den Blitz."
          }
        }
      }
    },
    "Start Measurement": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Messung starten"
          }
        }
      }
    },
    "Camera access is required to measure your pulse. Please allow it in Settings.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für die Pulsmessung wird Zugriff auf die Kamera benötigt. Bitte erlaube ihn in den Einstellungen."
          }
        }
      }
    },
    "Open Settings": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einstellungen öffnen"
          }
        }
      }
    },
    "Hold still …": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruhig halten …"
